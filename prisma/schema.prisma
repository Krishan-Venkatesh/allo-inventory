// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  url      = env("DATABASE_URL")
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  
}

model Product {
  id           String          @id @default(cuid())
  name         String
  sku          String          @unique
  description  String?
  priceInPaise Int             // store in smallest currency unit
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  stocks       InventoryStock[]
  reservations Reservation[]
}

model Warehouse {
  id        String           @id @default(cuid())
  name      String
  city      String
  createdAt DateTime         @default(now())
  stocks    InventoryStock[]
  reservations Reservation[]
}

model InventoryStock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  totalUnits  Int       @default(0)
  reserved    Int       @default(0)  // units currently held by pending reservations

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])  // one row per product-warehouse pair
  @@index([productId])
  @@index([warehouseId])
}

model Reservation {
  id          String            @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int
  status      ReservationStatus @default(PENDING)
  expiresAt   DateTime
  confirmedAt DateTime?
  releasedAt  DateTime?
  createdAt   DateTime          @default(now())

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  @@index([status, expiresAt])  // for expiry cleanup queries
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  RELEASED
}

// Idempotency keys (bonus)
model IdempotencyRecord {
  key        String   @id
  statusCode Int
  body       String   // JSON stringified response
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  @@index([expiresAt])
}